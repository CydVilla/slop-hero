{
  "name": "slop-hero",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "license": "MIT",
  "description": "A Tesla-browser-friendly, touchscreen rhythm game (Clone Hero / Rock Band style) built with Next.js.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze:metrics": "node scripts/apply-tuning.mjs",
    "audit:catalog": "node scripts/audit-catalog.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
